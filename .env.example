# Google Sheets output
GOOGLE_SHEET_ID=put_your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional Supabase dedup database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Runtime controls
MAX_PER_SOURCE=150
MAX_HTML_SOURCES_PER_RUN=35
MAX_COMPANIES_PER_RUN=80
MAX_HTML_LINKS_PER_SOURCE=80
MAX_REVIEW_ROWS=500
WRITE_REVIEW_QUEUE=true
VALIDATE_JOB_LINKS=false
RUN_MODE=strict
